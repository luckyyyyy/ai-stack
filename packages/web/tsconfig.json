{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client"],
    "paths": {
      "*": ["./*"],
      "@/*": ["./src/*", "../server/src/*"],
      "@server/*": ["../server/src/*"]
    }
  },
  "include": ["src"]
}
