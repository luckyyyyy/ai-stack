{
  "name": "@acme/server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "predev": "pnpm -C ../types build && pnpm -C ../i18n build",
    "gen:trpc": "tsx scripts/generate-trpc-types.ts",
    "gen:trpc:watch": "tsx scripts/generate-trpc-types.ts --watch",
    "dev": "concurrently -n trpc,server \"pnpm gen:trpc:watch\" \"node --require @swc-node/register --watch src/main.ts\"",
    "prebuild": "pnpm -C ../types build && pnpm -C ../i18n build",
    "build": "pnpm gen:trpc && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "db:migrate": "drizzle-kit push"
  },
  "dependencies": {
    "@acme/i18n": "workspace:*",
    "@acme/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@hono/node-server": "^1.19.9",
    "@hono/trpc-server": "^0.4.2",
    "@trpc/server": "^11.11.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
