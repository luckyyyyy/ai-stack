{
  "name": "@acme/server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "predev": "pnpm -C ../types build && pnpm -C ../i18n build",
    "gen:trpc": "tsx scripts/generate-trpc-types.ts",
    "gen:trpc:watch": "tsx scripts/generate-trpc-types.ts --watch",
    "dev": "concurrently -n trpc,server \"pnpm gen:trpc:watch\" \"tsx watch src/main.ts\"",
    "prebuild": "pnpm -C ../types build && pnpm -C ../i18n build",
    "build": "pnpm gen:trpc && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "db:migrate": "drizzle-kit push"
  },
  "dependencies": {
    "@acme/i18n": "workspace:*",
    "@acme/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@hono/node-server": "^1.13.8",
    "@hono/trpc-server": "^0.3.4",
    "@trpc/server": "^11.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.4",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/pg": "^8.11.10",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.4",
    "ts-morph": "^27.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  }
}
